# Copy to .env or export these in your shell before running the app.
# Example:
#   set -a; source .env; set +a
#   mvn spring-boot:run

SFTP_HOST=sftp.example.com
SFTP_PORT=22
SFTP_USERNAME=my-user
SFTP_PRIVATE_KEY_PATH=/Users/me/.ssh/id_rsa
SFTP_PRIVATE_KEY_PASSPHRASE=change-me
SFTP_HOST_KEY_VERIFICATION=STRICT
SFTP_KNOWN_HOSTS_PATH=/Users/me/.ssh/known_hosts
SFTP_REMOTE_DIRECTORY=/upload/demo
SFTP_CREATE_REMOTE_DIRECTORY_IF_MISSING=true
SFTP_TIMEOUT_MILLIS=10000
